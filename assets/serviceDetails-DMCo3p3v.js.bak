const e={"PAN Card Apply":{overview:"PAN Card Apply details include the exact document checklist required for a new PAN application.",openings:[{title:"PAN Card Apply",feeHeading:"Price",feeItems:["Apply Seva platform fee applies"],sections:[{heading:"PAN Card Apply – Documents Required",items:["Aadhaar Card","Passport Size Photo","Signature","Mobile Number","Email ID","Address Proof (Aadhaar Card, Electricity Bill, Bank Passbook, Ration Card, Passport)","Date of Birth Proof (Aadhaar Card, Birth Certificate, 10th Marksheet, Passport)"]}]}]},"PAN Card Correction":{overview:"PAN Card Correction details include the exact documents required to update or correct existing PAN information.",openings:[{title:"PAN Card Correction",feeHeading:"Price",feeItems:["Apply Seva platform fee applies"],sections:[{heading:"PAN Card Correction – Documents Required",items:["Old PAN Card Copy","Aadhaar Card","Passport Size Photo","Signature","Mobile Number","Email ID","Correction Proof (Aadhaar Card, 10th Marksheet, Passport, Bank Passbook, Marriage Certificate)"]}]}]},"Voter ID Apply":{overview:"Voter ID Apply details include the exact identity, address, and age proof checklist for new voter registration.",openings:[{title:"Voter ID Apply",feeHeading:"Price",feeItems:["Price - free"],sections:[{heading:"Voter ID Apply – Documents Required",items:["Aadhaar Card","Passport Size Photo","Mobile Number","Identity Proof (Aadhaar Card, PAN Card, Passport, Driving Licence)","Address Proof (Aadhaar Card, Electricity Bill, Rent Agreement, Bank Passbook, Ration Card)","Age Proof (Birth Certificate, 10th Marksheet, Aadhaar Card)"]}]}]},"Voter ID Correction":{overview:"Voter ID Correction details include the exact documents required for correcting existing voter ID details.",openings:[{title:"Voter ID Correction",feeHeading:"Price",feeItems:["Price - free"],sections:[{heading:"Voter ID Correction – Documents Required",items:["Old Voter ID Copy","Aadhaar Card","Passport Size Photo","Mobile Number","Correction Proof (Aadhaar Card, 10th Marksheet, Birth Certificate, Address Proof, Passport)"]}]}]},"PVC Aadhaar Order":{overview:"PVC Aadhaar Card order details are kept simple because no physical document upload is required for ordering the card.",openings:[{title:"PVC Aadhaar Card",feeHeading:"Application Fee",feeItems:["Government application fee: Rs 50/-"],sections:[{heading:"Required Details Card (No Documents Needed)",items:["Aadhaar Identity: Aapko apna 12-digit Aadhaar Number ya 28-digit Enrollment ID (EID) pata hona chahiye.","Mobile Registered Hai: myAadhaar portal par login karke updated address aur photo dekh kar order place kar sakte hain.","Mobile Registered Nahi Hai: Non-registered ya alternate mobile number ka use karke OTP manga sakte hain aur face validation ya bina profile login ke order place kar sakte hain."]}]}]},"Ayushman Card":{overview:"Ayushman Card eligibility and identity requirements are grouped here so users can quickly check whether their family is eligible.",openings:[{title:"Ayushman Card",feeHeading:"Application Fee",feeItems:["Application fee: Free"],sections:[{heading:"Required Identity & Eligibility Documents",items:["Eligibility: Ayushman Card sirf unhi logon ka banta hai jinka naam SECC-2011 data ya ration card list me shamil hai.","Identity Proof: Aadhaar Card online e-KYC aur biometric/OTP verification ke liye mandatory hai.","Family Eligibility Proof: Ration Card jisme parivar ke sabhi members ka naam ho.","Family Eligibility Proof: PM Letter, yani Pradhan Mantri dwara bheja gaya parivar ke naam ka official alert letter.","Contact Info: Aadhaar se linked active Mobile Number jispar verification OTP aayega."]}]}]},"ABHA Health Card":{overview:"ABHA Health Card can be created online with identity verification, usually without any physical certificate or form.",openings:[{title:"ABHA Health Card",feeHeading:"Application Fee",feeItems:["Application fee: Free"],sections:[{heading:"Required Identity Documents",items:["Aadhaar Card (Most Recommended): Isse sabse fast online verification hota hai.","Aadhaar Condition: Mobile number Aadhaar card se linked hona mandatory hai, kyunki verification ke liye OTP aayega.","Driving License (Alternative Option): Aadhaar use nahi karna chahte toh Driving License ke zariye enrollment code generate hota hai, jise baad me verify karwana hota hai.","Contact Info: Active Mobile Number jahan registration aur login OTPs receive ho sakein."]}]}]},"E-Shram Card":{overview:"E-Shram Card requirements are for unorganized sector workers who are not EPFO/ESIC members.",openings:[{title:"E-Shram Card",feeHeading:"Application Fee",feeItems:["Application fee: Free"],sections:[{heading:"Required Identity & Bank Documents",items:["Eligibility: E-Shram card unorganized sector workers ke liye hai, jaise rajmistry, majdoor, khomchewaale, bidi mazdoor, delivery boys, driver, etc., jo EPFO/ESIC ke member nahi hain.","Aadhaar Card: Personal details aur biometric verification ke liye mandatory hai.","Aadhaar Mobile Note: Mobile number Aadhaar se linked hona chahiye taaki OTP verify ho sake.","Bank Account Details: Bank account number aur IFSC Code zaroori hai, kyunki sarkari arthik madad ya subsidy DBT ke zariye isi account me aati hai.","Contact Info: Active Mobile Number."]}]}]},"PM Kisan Registration":{overview:"PM Kisan Registration details include the exact document checklist required for farmer registration and eKYC process.",openings:[{title:"PM Kisan Registration",feeHeading:"Price",feeItems:["Apply Seva platform fee applies"],sections:[{heading:"PM Kisan Registration – Documents Required",items:["Aadhaar Card","Bank Passbook","Mobile Number Linked with Aadhaar","Passport Size Photo","Land Record / Khata-Khesra Copy","Farmer ID (if available)","Email ID (Optional)"]}]}]},"Labour Card":{overview:"Labour Card details are for eligible construction workers and include state-wise fee, work proof, bank, and identity requirements.",openings:[{title:"Labour Card",feeHeading:"Registration Fee",feeItems:["Registration fee: State ke hisab se approx Rs 20/- to Rs 50/-","Annual contribution fee: Approx Rs 10/- to Rs 20/- per year"],sections:[{heading:"Required Identity & Bank Documents",items:["Eligibility: Card unhi mazdooron ka banta hai jo saal me kam se kam 90 din construction work me majdoor, carpenter, electrician, painter, ya plumber ke roop me kaam kiye hon.","Identity Proof: Aadhaar Card mandatory verification aur demographic data ke liye.","Address Proof: Domicile (Niwasi) Certificate, Voter ID, ya Rashan Card.","90 Din ka Work Certificate: Contractor, gram pradhan, ya ward parshad dwara signed praman patra jo prove kare ki aapne 90 din mazdoori ki hai.","Bank Account Details: Bank Passbook copy, kyunki sarkari labh ka paisa directly isi account me aata hai.","Passport Photo: 2 se 3 fresh color photographs."]}]}]},"Income Certificate Apply":{overview:"Income Certificate Apply details are grouped here with the exact document checklist.",openings:[{title:"Income Certificate Apply",feeHeading:"Price",feeItems:["Free"],sections:[{heading:"Income Certificate – Documents Required",items:["Aadhaar Card","Passport Size Photo","Mobile Number"]}]}]},"Caste Certificate Apply":{overview:"Caste Certificate Apply details are grouped here with the exact document checklist.",openings:[{title:"Caste Certificate Apply",feeHeading:"Price",feeItems:["Free"],sections:[{heading:"Caste Certificate – Documents Required",items:["Aadhaar Card","Passport Size Photo","Mobile Number"]}]}]},"Residence/Domicile Certificate":{overview:"Residence/Domicile Certificate details are grouped here with the exact document checklist.",openings:[{title:"Residence/Domicile Certificate",feeHeading:"Price",feeItems:["Free"],sections:[{heading:"Residence Certificate – Documents Required",items:["Aadhaar Card","Passport Size Photo","Mobile Number"]}]}]},"Birth Certificate":{overview:"Birth Certificate details include registration fee timing, benefits, and supporting documents for normal or delayed registration.",openings:[{title:"Birth Certificate",feeHeading:"Government Registration Fee",feeItems:["Within 21 Days: Registration Free (Nil).","21 Days to 30 Days: Approx Rs 2/- to Rs 5/- late fee.","After 30 Days up to 1 Year: Block/SDO permission and approx Rs 5/- to Rs 10/- late fee.","After 1 Year: Magistrate order/Affidavit ke sath approx Rs 10/- to Rs 50/- fee."],feeNote:"Benefits: Birth Certificate sabse pehla age aur identity proof hota hai, jo school admission, passport, aur government IDs banwane me kaam aata hai.",sections:[{heading:"Required Supporting Documents Card",items:["Hospital Discharge Certificate: Government ya private hospital se mila Discharge Slip ya Institutional Birth Record.","Parents Identity Proof: Mata-pita dono ke valid ID proofs, jaise PAN Card, Voter ID, Passport, ya Driving License.","Address Proof: Parents ke naam ka Electricity Bill, Water Bill, ya Rashan Card.","Affidavit: Agar 21 din ke baad apply kar rahe hain, toh notary verified affidavit jisme janm ki tarikh, jagah aur deri ka karan likha ho.","No Objection Certificate (NOC): Local body, Nagar Nigam, ya Gram Panchayat se certificate ki pehle birth registration nahi hua hai."]}]}]},"Death Certificate":{overview:"Death Certificate details include registration fee timing and the documents needed by nominee or family member.",openings:[{title:"Death Certificate",feeHeading:"Government Registration Fee",feeItems:["Within 21 Days: Registration Free (Nil).","21 Days to 30 Days: Approx Rs 2/- to Rs 5/- late fee.","30 Days to 1 Year: Block/SDO written permission and nominal late fee.","After 1 Year: Magistrate/Executive Magistrate permission and Affidavit ke sath approx Rs 10/- to Rs 50/- fee."],sections:[{heading:"Required Supporting Documents Card",items:["Hospital Death Summary / Cremation Receipt: Hospital death ke liye Death Report/Summary Copy; ghar par death ke liye Cremation/Burial Receipt ya local doctor certificate.","Deceased Identity Proof: Mritak ke valid identity proofs, jaise PAN Card, Voter ID, ya Passport, jisse naam aur umar verify ho sake.","Applicant Identity Proof: Jo family member apply kar raha hai, unka Aadhaar Card ya koi valid ID proof.","Address Proof: Mritak ke ghar ka address proof, jaise Electricity Bill ya Ration Card.","Notary Affidavit: Agar 1 saal baad apply kar rahe hain, toh stamp paper par verified affidavit jisme mritak details, death date, jagah aur deri ka karan ho.","Magistrate Order: Area ke SDM ya Executive Magistrate dwara jaari delayed registration permission letter."]}]}]},"Passport Apply":{overview:"Passport application details are grouped by fee type and document category so applicants can prepare originals and self-attested copies for PSK.",openings:[{title:"Passport Apply",feeHeading:"Application Fee & Types Card",feeItems:["Fresh / Renewal (36 Pages): Normal Scheme Rs 1500/-; Tatkaal Scheme Rs 3500/- (1500 + 2000); Normal processing 15-30 days; Tatkaal processing 1-3 days.","Fresh / Renewal (60 Pages): Normal Scheme Rs 2000/-; Tatkaal Scheme Rs 4000/- (2000 + 2000); Normal processing 15-30 days; Tatkaal processing 1-3 days.","Minor (Below 18 Years): Normal Scheme Rs 1000/-; Tatkaal Scheme Rs 3000/- (1000 + 2000); validity 5 years or till 18 years."],sections:[{heading:"Required Base Documents Card (Any One From Each Category)",items:["Proof of Date of Birth: Birth Certificate, 10th Class Matriculation Marksheet/Passing Certificate, PAN Card, ya Driving License.","Proof of Present Address: Water Bill, Electricity Bill, Telephone/Gas Connection Bill, Bank Account Passbook with photo and stamp, Registered Rent Agreement, ya Voter ID Card.","Non-ECR Category Proof: Agar 10th Class ya usse zyada padhe-likhe hain, toh Educational Degree/Marksheet lagayein taaki passport Non-ECR category me ban sake.","PSK Visit Note: Passport Office jaate waqt original documents aur self-attested xerox copies lekar jaana hota hai."]}]}]},"Driving Licence Apply":{overview:"Driving Licence details are split into fee components and core documents needed for learner or permanent licence application.",openings:[{title:"Driving Licence Apply",feeHeading:"DL Application Fee & Categories Card",feeItems:["Learner's License (LL): Approx Rs 150/- per class + Rs 50/- test fee.","Driving License (DL) Issue: Approx Rs 200/- for permanent licence.","DL Driving Test Fee: Approx Rs 300/- per class at RTO.","Smart Card Form Fee: Approx Rs 200/- for plastic chip-enabled smart card."],sections:[{heading:"Required Core Documents Card",items:["Base Identity & Address Proof: Aadhaar Card, Voter ID Card, Passport, Life Insurance Policy, Ration Card, ya Electricity/Gas Bill.","Age Proof: 10th Class Matriculation Marksheet/Passing Certificate, Birth Certificate, ya PAN Card.","Learner's License Number: Active LL number mandatory hai, kyunki iske bina permanent DL form nahi khulega.","Form 1 (Self-Declaration): Physical fitness ka self-declaration form, jo online tick karna hota hai.","Form 1A (Medical Certificate): Agar age 40 se zyada hai ya Commercial/Transport vehicle ke liye apply kar rahe hain, toh Government Doctor se signed Medical Certificate mandatory hai."]}]}]},"Railway Form":{overview:"Current railway recruitment openings are listed below with clearly labeled last dates, fee details, and document requirements.",openings:[{title:"Railway RRB ALP",lastDateLabel:"Online Apply Last Date",lastDate:"14 June 2026",feeHeading:"Fee Details",feeItems:["General/ OBC Candidates : ₹ 519/-","SC/ ST/ PwBD Ex-Serviceman Candidates : ₹ 250/-"],sections:[{heading:"Documents",items:["Aadhaar Card / Voter ID / PAN Card / Driving Licence","Active Mobile Number & Email ID","Live Photograph & Signature","10th Certificate / ITI / Diploma / Degree Documents","Category Certificate (SC/ST/OBC/EWS if applicable)","Aadhaar Linked Bank Account Details","Ex-Servicemen / Minority / EBC Documents (if applicable)","Medical Self-Declaration Documents"]}]},{title:"Railway SECR Apprentices Examination 2026",lastDateLabel:"Online Apply Last Date",lastDate:"11 June 2026",feeHeading:"Fee Details",feeItems:["For General / OBC Candidates: Rs 00/-","For SC / ST / EWS Candidates: Rs 00/-","For All Female Category Candidates: Rs 00/-"],feeNote:"South East Central Railway (SECR) Act Apprentice Recruitment 2026 ke online form aur Document Verification ke liye neeche card-wise documents diye gaye hain.",sections:[{heading:"Portal Note",items:["Aapko iska form official Apprenticeship India portal par jaakar bharna hoga."]},{heading:"Personal & Identity Card",items:["Identity Proof: Aadhaar Card (mandatory Aadhaar Verification ke liye). PAN Card ya Driving License backup ke liye rakh sakte hain.","Passport Photo: Recent passport size color photograph (scanned copy).","Signature: White paper par blue/black ink se kiya hua scanned signature.","Contact Info: Active Mobile Number aur Email ID."]},{heading:"Academic & ITI Certificate Card",items:["Important Notice: Form me sirf 10th aur ITI ke marks fill karein. Higher qualification fill karne par form reject ho sakta hai.","10th Class (Matriculation): Marksheet aur Passing Certificate, minimum 50% aggregate marks ke sath.","ITI (Trade Course): NCVT ya SCVT recognized relevant trade ka ITI Marksheet aur National Trade Certificate (NTC)."]},{heading:"Reservation & Medical Card",items:["Caste Certificate: SC / ST / OBC candidates ke liye Central Government format me certificate. OBC NCL 1 saal se purana nahi hona chahiye.","Disability (PwBD) Certificate: Minimum 40% disability praman patra.","Ex-Servicemen Certificate: Agar discharge certificate ya ex-servicemen quota claim kar rahe hain.","Medical Fitness Certificate: Selection ke baad Government-authorized Gazetted Doctor se signed fitness certificate chahiye hoga."],note:"Crucial Check: 10th Marksheet, ITI Marksheet, Aadhaar, aur PAN Card me naam aur father name exact match hona chahiye."}]},{title:"Railway SECR Apprentices Examination 2026",lastDateLabel:"Online Apply Last Date",lastDate:"04 June 2026",feeHeading:"Fee Details",feeItems:["For General / OBC Candidates: Rs 00/-","For SC / ST / EWS Candidates: Rs 00/-","For All Female Category Candidates: Rs 00/-"],sections:[{heading:"Personal & Identity Card",items:["Identity Proof: Aadhaar Card (profile registration aur verification ke liye mandatory). PAN Card ya Driving License backup ke liye rakh sakte hain.","Passport Photo: Recent color photograph (scanned copy, clear background).","Signature: White paper par blue/black ink se kiya hua clear scanned signature.","Contact Info: Active Mobile Number aur Email ID."]},{heading:"Academic & ITI Certificate Card",items:["Important: Form me sirf 10th aur ITI ke marks enter karein. Higher qualification fill karne par shortlisting me problem aa sakti hai.","10th Class (Matriculation): Marksheet aur Passing Certificate, minimum 50% aggregate marks ke sath.","ITI Certificate: NCVT ya SCVT se recognized relevant trade ka ITI Marksheet aur National Trade Certificate (NTC)."]},{heading:"Reservation & Medical Card",items:["Caste Certificate: SC / ST / OBC candidates ke liye Central Government format me certificate. OBC NCL 1 saal se purana nahi hona chahiye.","Disability (PwBD) Certificate: Minimum 40% disability praman patra.","Ex-Servicemen Certificate: Agar ex-servicemen quota ya discharge certificate ka benefit claim kar rahe hain.","Medical Fitness Certificate: DV ke waqt Government-authorized Gazetted Doctor se signed fitness certificate submit karna hoga."],note:"Crucial Check: 10th Marksheet, ITI Marksheet aur baaki IDs me naam, father name aur DoB exact match hona chahiye."}]}]},"Teacher Vacancy Form":{overview:"Teacher and education recruitment-related forms are grouped here with separate headings for fee structure and required documents.",openings:[{title:"CTET September",lastDateLabel:"Online Apply Last Date",lastDate:"10 June 2026",feeHeading:"Fee Details",feeItems:["For Paper-I - General / OBC: Rs 1000/-","For Paper-I - SC / ST / PWD: Rs 500/-","For Both Paper - General / OBC: Rs 1200/-","For Both Paper - SC / ST / PWD: Rs 600/-"],feeNote:"Platform fee applies separately.",sections:[{heading:"Documents",items:["Aadhaar Card / Any Valid ID Proof","Passport Size Photograph","Signature Scan Copy","10th Marksheet & Certificate","12th Marksheet & Certificate","Graduation Marksheet / Degree","B.Ed / D.El.Ed / BTC / Teacher Training Certificate (if applicable)","Category Certificate (SC/ST/OBC/EWS/PwD if applicable)","Active Mobile Number & Email ID"]}]},{title:"Bihar CET B.Ed Examination 2026",lastDateLabel:"Last Date for Apply Online",lastDate:"18 May 2026",feeHeading:"Fee Details",feeItems:["For General: Rs 1000/-","For EWS / BC / EBC / Women: Rs 750/-","For SC / ST Candidates: Rs 500/-"],sections:[{heading:"Photo aur Signature (Scanned)",items:["Passport Photo: Recent passport size photo (color).","Signature: White paper par blue/black ink se kiya hua."]},{heading:"Academic Documents",items:["10th & 12th: Marksheet aur Certificate (DoB proof ke liye).","Graduation: Marksheet (minimum 50% ya B.Tech ke liye 55% required).","Post-Graduation: Marksheet (agar applicable ho toh)."]},{heading:"Identity aur Residence Proof",items:["ID Proof: Aadhaar Card, Voter ID, ya Driving License.","Domicile Certificate: Agar Bihar resident hain aur reservation chahiye."]},{heading:"Category Certificates (Agar applicable ho)",items:["Caste Certificate: BC / EBC / SC / ST ke liye.","EWS Certificate: Economically Weaker Section ke liye.","PwD Certificate: Persons with Disabilities ke liye."],note:"Form bharne ke liye ek active mobile number aur email ID zaroori hai jahan OTP aur notifications aayenge."}]}]},"Exam Form Fillup":{overview:"NTA and competitive exam form details are organized exam-wise so each deadline, fee category, and document checklist stays inside the correct exam card.",openings:[{title:"NTA ICAR AIEEA PG and PHd Examination 2026",lastDateLabel:"Apply Online Last Date",lastDate:"07 June 2026",feeHeading:"Fee Details",feeItems:["AIEEA PG Course - For General: Rs 1300/-","AIEEA PG Course - For OBC / EWS: Rs 1255/-","AIEEA PG Course - For SC / ST / PH: Rs 675/-","AIEEA JRF/SRF (PHd) Agricultural Research Courses - For General: Rs 2000/-","AIEEA JRF/SRF (PHd) Agricultural Research Courses - For EWS / OBC: Rs 1955/-","AIEEA JRF/SRF (PHd) Agricultural Research Courses - For SC / ST / PH: Rs 1075/-"],sections:[{heading:"Personal & Identity Card",items:["Identity Proof: Aadhaar Card online registration aur biometric mapping ke liye highly recommended hai. Agar Aadhaar nahi hai, toh PAN Card, Passport, ya Driving License use kar sakte hain.","Passport Size Photo: Hal hi me kheenchi gayi color photograph, white background ke sath, jisme candidate ka 80% chehra bina mask ke saaf dikhna chahiye. Scanned JPG upload ke liye rakhein.","Signature: White paper par blue/black ink se kiya hua clear scanned signature.","Thumb Impression: Left-hand thumb impression, yani baayein haath ke angoothe ka nishan, scanned copy form me upload karne ke liye.","Contact Info: Active Mobile Number aur Email ID, kyunki NTA admit card download link aur result updates isi par bhejega."]},{heading:"Academic & Institutional Qualification Card",items:["10th Class (Matriculation): Marksheet aur Certificate, name, father's name aur Date of Birth verification ke liye mandatory.","12th Class (Intermediate): Marksheet aur Certificate.","For PG Applicants (Graduation Documents): B.Sc. Agriculture ya relevant stream ki degree certificate/provisional certificate aur sabhi semesters ki marksheets.","For Ph.D. Applicants (Post-Graduation Documents): M.Sc. Agriculture ya relevant Master's degree ka certificate aur transcript.","University Accreditation Certificate: Aisa certificate jo confirm kare ki graduation/post-graduation jis college/university se hui hai, wo ICAR se accredited hai. Yeh counselling ke waqt bahut zaroori hota hai."]},{heading:"Reservation & State Domicile Card (Agar applicable ho)",items:["Caste/Category Certificate: SC / ST / OBC-NCL Central List ke mutabik candidates ke liye competent authority dwara jaari certificate. OBC-NCL certificate 1 April 2026 ke baad issue hua hona chahiye.","EWS Certificate: General category ke Economically Weaker Section candidates ke liye valid income and asset certificate.","PwBD Certificate: Physical Disability candidates ke liye minimum 40% disability praman patra, taaki exam me extra time ya scribe ki suvidha mil sake."],note:"Important Form-Filling Note: NTA portal par form bharte waqt subjects aur city choices bohot dhyan se select karein, kyunki submit hone ke baad correction window me sirf limited details edit karne ka mauka milta hai."}]},{title:"NTA UGC NET June Examination 2026",lastDateLabel:"Apply Online Last Date",lastDate:"20 May 2026",feeHeading:"Fee Details",feeItems:["For General: Rs 1150/-","For OBC / EWS: Rs 600/-","For SC / ST / PH: Rs 325/-"],sections:[{heading:"Personal & Identity Card",items:["Identity Proof: Aadhaar Card online registration aur biometric data sync ke liye best hai. Agar Aadhaar nahi dena chahte, toh PAN Card, Passport, ya Voter ID select kar sakte hain.","Passport Size Photo: Recent color photograph, plain white background ke sath, jisme 80% chehra bina mask ke aur dono kaan saaf dikhne chahiye. Scanned JPG size 10kb-200kb.","Signature: White paper par black ink pen se kiya hua clear scanned signature. Scanned JPG size 4kb-30kb.","Contact Info: Active Mobile Number aur Unique Email ID, kyunki NTA application number aur future updates isi par bhejega."]},{heading:"Academic Qualification Card",items:["Eligibility Check: Master's Degree (Post-Graduation) me minimum 55% aggregate marks mandatory hai. OBC-NCL / SC / ST / PwD / Transgender candidates ke liye minimum 50% aggregate marks required hain. Final year ya awaiting result candidates bhi apply kar sakte hain.","10th Class Certificate: Exact name, father's name aur Date of Birth (DoB) match karne ke liye base document.","Master's Degree Certificate / Marksheet: Agar PG pass out hain, toh final year marksheet ya degree certificate chahiye, jisme exact marks aur pass year enter karna hoga.","Awaiting/Appearing Proof: Agar final semester me hain, toh college/subject details form me Result Awaited option select karke bharna hoga."]},{heading:"Category & Special Reservation Card (Agar applicable ho)",items:["Category Certificate: SC / ST / OBC-NCL candidates ke liye competent authority dwara jaari certificate.","OBC Note: OBC candidates nishchit karein ki unka certificate Central List ke mutabik ho aur updated ho.","EWS Certificate: General category ke Economically Weaker Section candidates ke liye valid income proof.","PwD Certificate: Physical Disability candidates ke liye minimum 40% disability praman patra, taaki exam center par extra time (20 min per hour) ya scribe facility mil sake."],note:"Important Tip: Form fill karte waqt NET Subject, Post-Graduation subject ke mutabik, aur Exam City Choices bohot dhyan se bharein, kyunki submit hone ke baad city allocation me limited changes mil sakte hain."}]}]},"Navy Form":{overview:"Indian Navy openings under this card include the latest fee note and detailed document checklist.",openings:[{title:"Indian Navy SSC Executive IT",lastDateLabel:"Online Apply Last Date",lastDate:"01 June 2026",feeHeading:"Fee Details",feeItems:["No application fee is required for any candidate."],sections:[{heading:"Documents",items:["Aadhaar Card / PAN Card / Voter ID / Passport","Passport Size Photograph","Signature Scan Copy","10th Marksheet & Certificate","12th Marksheet & Certificate","B.Tech / BE Degree Certificate","Semester-wise Marksheet","CGPA to Percentage Conversion Certificate (if applicable)","NCC Certificate (if applicable)","Category Certificate (SC/ST/OBC/EWS if applicable)","Valid Email ID & Mobile Number","Domicile Certificate (if required)","Recent Resume / Personal Details","Scanned Copies of All Original Documents"],note:"Important: Photograph, signature aur documents clear scanned format me hone chahiye aur application details documents se match karni chahiye."}]}]},"Bihar Police Form":{overview:"Bihar Police-related forms are listed separately here so fee and qualification requirements stay tied to the correct post.",openings:[{title:"Bihar Police BPSSC ASI (Technical)",lastDateLabel:"Online Apply Last Date",lastDate:"21 June 2026",feeHeading:"Fee Details",feeItems:["For All Category Candidates: Rs 100/-"],sections:[{heading:"Personal & Identity Card",items:["Identity Proof: Aadhaar Card, PAN Card, ya Driving License.","Passport Photo: Fresh color photograph (JPEG format).","Signature: Do alag files, ek Hindi me aur ek English me scan ki hui.","Contact Details: Active Mobile Number aur Email ID."]},{heading:"Technical & Academic Certificate Card",items:["10th (Matriculation): Marksheet aur Passing Certificate, Date of Birth proof ke liye mandatory.","12th (Intermediate): Marksheet aur Certificate (agar kiya ho toh).","Technical Diploma: 3-Year Polytechnic Diploma ki marksheet aur certificate, minimum 50% marks (45% for SC/ST) ke sath.","Eligible Streams: Electronics & Communication, Electronics & Telecommunication, Information Technology (IT), Electrical & Electronics."]},{heading:"Bihar Reservation & Category Card",items:["Domicile (Niwasi) Certificate: Bihar ka mool niwasi pramaan patra.","Caste Certificate: SC / ST candidates ke liye.","NCL Certificate: BC aur EBC candidates ke liye Non-Creamy Layer praman patra.","EWS Certificate: General category ke Economically Weaker Section candidates ke liye."]}]}]},"State Govt Job Form":{overview:"State-level and public recruitment updates are grouped under clearly marked openings so dates, fees, and document lists remain separated.",openings:[{title:"BPSC 72nd Pre",lastDateLabel:"Online Apply Last Date",lastDate:"31 May 2026",feeHeading:"Fee Details",feeItems:["For All Category Candidates: Rs 100/-"],feeNote:"Fees Note: Application fee Rs 100 hai, lekin registration ke waqt Aadhaar Card number nahi dene par Rs 200 extra biometric fee deni hogi.",sections:[{heading:"Documents",items:["Aadhaar Card / Voter ID / PAN Card / Driving Licence","Passport Size Photograph","Signature Scan Copy","10th Marksheet & Certificate (Date of Birth Proof)","Graduation Marksheet / Degree Certificate","Caste Certificate (SC/ST/OBC/EBC if applicable)","EWS Certificate (if applicable)","PwD Certificate (if applicable)","Domicile / Residence Certificate (if applicable)","Active Mobile Number & Email ID","Aadhaar Linked Bank Details (if required)","Valid ID Proof for Exam Day"],note:"Important: Sabhi documents clear scanned format me hone chahiye aur application form ki details documents se exactly match karni chahiye."}]},{title:"UPSSSC Cane Supervisor Examination 2026",lastDateLabel:"Online Apply Last Date",lastDate:"28 July 2026",feeHeading:"Fee Details",feeItems:["For General / OBC / EWS: Rs 25/-","For SC / ST: Rs 25/-","For PH Candidates: Rs 25/-"],sections:[{heading:"Mandatory Pre-Requisite & Identity Card",items:["UPSSSC PET 2025 Score Card: Valid PET 2025 registration number mandatory hai. Zero ya negative marks wale apply nahi kar sakte.","Identity Proof: Aadhaar Card, PAN Card, ya Driving License.","Photo & Signature: Fresh passport size photo aur clear scanned signature."]},{heading:"Academic & Mandatory Technical Qualification Card",items:["10th Class (Matriculation): Marksheet aur Certificate.","12th Class (Intermediate): Marksheet aur Certificate.","Graduation in Agriculture: B.Sc. Agriculture ya equivalent degree aur marksheet.","Computer Certification: NIELIT CCC ya O Level computer certificate compulsory hai."]},{heading:"UP Reservation & Category Card",items:["Domicile (Mool Niwasi) Certificate: UP ka niwasi pramaan patra.","Caste Certificate: OBC / SC / ST categories ke liye updated format me.","EWS Certificate: Economically Weaker Section relaxation ke liye.","PwD / Ex-Servicemen Certificate: Agar applicable ho toh."]}]}]},"Army Form":{overview:"Indian Army openings are listed separately below, with eligibility and SSB-related document requirements clearly marked.",openings:[{title:"Indian Army 10+2 TES 56 Examination 2026",lastDateLabel:"Apply Online Last Date",lastDate:"12 June 2026",feeHeading:"Fee Details",feeItems:["No application fee is required."],sections:[{heading:"Personal & Identity Card",items:["Passport Size Photograph: Recent color photograph (scanned copy).","Signature: White paper par clear scanned signature.","Identity Proof: Aadhaar Card, PAN Card, ya Passport.","Contact Info: Active Mobile Number aur Valid Email ID."]},{heading:"Academic & JEE Main Score Card",items:["Important Eligibility: 10+2 me Physics, Chemistry aur Mathematics me minimum 60% aggregate marks aur JEE Main 2026 me appear hona mandatory hai.","10th Class Marksheet & Passing Certificate: Name, father name aur exact DoB proof.","12th Class Marksheet & Passing Certificate: PCM marks aur board verification ke liye.","JEE Main 2026 Scorecard / Result Copy: Application Number aur NTA score ke sath."]},{heading:"Special Certificates & SSB Specifics",items:["Marital Status Certificate: Entry sirf unmarried male candidates ke liye hai.","Category Certificate: Agar kisi relaxation category se belong karte hain.","Two Printouts of Application Form: Roll Number ke sath SSB ke liye surakshit rakhein."]}]},{title:"Indian Army TGC 146 Examination 2026",lastDateLabel:"Apply Online Last Date",lastDate:"11 June 2026",feeHeading:"Fee Details",feeItems:["No application fee is required for any candidate."],sections:[{heading:"Personal & Identity Card",items:["Identity Proof: Aadhaar Card, PAN Card, Voter ID, ya Passport.","Passport Size Photo: Recent color photograph clear background ke sath.","Signature: White paper par blue/black ink se kiya hua scanned signature.","Contact Info: Active Mobile Number aur Email ID."]},{heading:"Engineering & Academic Qualification Card",items:["Eligibility Check: Entry sirf unmarried male engineering graduates ya final year B.E./B.Tech students ke liye hai. Age limit 20 se 27 saal hai.","10th Class Marksheet & Passing Certificate: Name, parents' name aur exact DoB match ke liye.","12th Class Marksheet & Certificate: Basic academic verification ke liye.","Engineering Degree / All Semesters Marksheets: First semester se final semester tak.","Final Year Certificate: Agar final year me hain toh Principal signed certificate upload karna hoga.","Cumulative CGPA to Percentage Conversion Formula: University approved conversion document sath rakhein."]},{heading:"Submission & SSB Interview Specific Card",items:["Two Printouts of Application Form: Roll Number ke sath SSB Interview ke liye compulsory hai.","Self-Attestation: Sabhi original documents ke sath 2 self-attested photocopy sets lekar jaana hota hai."]}]}]},"DRDO/ISRO Form":{overview:"PSU, technical, and specialist openings are grouped here with separate headings so fee notes and supporting documents stay aligned to the correct recruitment.",openings:[{title:"NFL Field Representative Examination 2026",lastDateLabel:"Online Apply Last Date",lastDate:"12 June 2026",feeHeading:"Fee Details",feeItems:["For General / OBC / EWS: Rs 200/-","For SC / ST: Rs 00/-"],sections:[{heading:"Personal & Identity Card",items:["Photograph: Fresh color passport-size photo (Scanned/JPEG).","Signature: White paper par blue ya black ink se kiya hua signature (Scanned/JPEG).","Identity & Address Proof: PAN Card, Aadhaar Card, Passport, ya Driving License.","Contact Info: Active Mobile Number aur Email ID."]},{heading:"Academic & Technical Qualification Card",items:["10th Class (Matriculation): Marksheet aur Certificate, DoB proof ke liye mandatory.","12th Class (Intermediate): Marksheet aur Certificate (agar details fill karni ho).","Diploma in Agriculture: Full-time B.Sc. (Agriculture) ya 2-Year / 3-Year Diploma / Polytechnic in Agriculture, minimum 50% marks ke sath; SC/ST/PwBD ke liye 45%.","Note: Horticulture ya uske sub-disciplines ke diploma holders eligible nahi hain."]},{heading:"Reservation & Category Card",items:["Caste Certificate: SC / ST / OBC candidates ke liye.","Income & Asset Certificate (EWS): General category EWS candidates ke liye.","PwBD Certificate: Benchmark disability benefit aur age relaxation ke liye.","Ex-Servicemen / Departmental Candidate Proof: Agar applicable ho."]}]},{title:"Coal India CIL Management Trainee MT (Through GATE)",lastDateLabel:"Online Apply Last Date",lastDate:"07 June 2026",feeHeading:"Fee Details",feeItems:["For General / OBC / EWS: Rs 1180/-","For SC / ST / PH: Rs 00/-"],sections:[{heading:"Personal & Identity Card",items:["Identity Proof: Aadhaar Card, PAN Card, Voter ID, ya Passport.","Passport Size Photo: Fresh color photograph with white background.","Signature: White paper par blue/black ink se kiya hua clear scanned signature.","Contact Info: Active Mobile Number aur Email ID."]},{heading:"GATE Score & Engineering Certificate Card",items:["Eligibility Check: Relevant GATE score aur graduation me minimum 60% marks (55% for SC/ST/PwD) mandatory hai.","GATE Scorecard: Official scorecard with AIR, score aur registration number.","10th Class Marksheet & Certificate: Name, father name aur DoB verification ke liye.","12th Class Marksheet & Certificate: Basic academic record ke liye.","Engineering Degree / Provisional Certificate: B.E./B.Tech/B.Sc (Engg.) final degree ya provisional.","Semester-wise Marksheets: Graduation ke sabhi semesters/years ki marksheets.","CGPA to Percentage Conversion Formula: University official conversion certificate mandatory hota hai."]},{heading:"Category & Special Certificates",items:["Caste Certificate: SC / ST / OBC (Non-Creamy Layer) candidates ke liye Central Government format me.","EWS Certificate: Valid income and asset certificate.","PwD Certificate: Minimum 40% disability praman patra.","No Objection Certificate (NOC): Government / Semi-Government / PSU me kaam kar rahe candidates ke liye."],note:"Important Note: Final year students apply kar sakte hain, lekin document verification tak degree ya final marksheet pesh karni hogi."}]},{title:"Coal India CIL Management Trainee MT Examination 2026",feeHeading:"Fee Details",feeItems:["For General / OBC / EWS: Rs 1180/-","For SC / ST / PH: Rs 00/-"],sections:[{heading:"Personal & Identity Card",items:["Identity Proof: Aadhaar Card, PAN Card, Voter ID, ya Passport.","Passport Size Photo: Fresh color photograph, preferably white background ke sath.","Signature: White paper par blue ya black ink se kiya hua clear scanned signature.","Contact Info: Active Mobile Number aur Email ID."]},{heading:"Academic & Engineering Qualification Card",items:["Eligibility Note: B.E. / B.Tech / B.Sc (Engineering) me minimum 60% aggregate marks (55% for SC/ST/PwD) compulsory hai.","10th Class Marksheet & Certificate: Name, father name aur DoB verification ke liye mandatory.","12th Class Marksheet & Certificate: Higher secondary proof ke roop me.","Engineering Degree / Provisional Certificate: Final degree ya provisional certificate PDF format me.","Semester-wise Marksheets: B.E./B.Tech ke sabhi semesters/years ki original marksheets.","CGPA to Percentage Conversion Formula: College ya university ke letterhead par approved conversion formula attach karna hoga."]},{heading:"Reservation & Category Card",items:["Caste Certificate: SC / ST / OBC (Non-Creamy Layer) candidates ke liye.","EWS Certificate: Valid income and asset certificate.","PwD Certificate: Minimum 40% disability praman patra.","No Objection Certificate (NOC): Government / Semi-Government / PSU organization me permanent post par kaam kar rahe candidates ke liye."],note:"Application Fee: General / OBC / EWS ke liye Rs 1180 (Rs 1000 base fee + GST), jabki SC / ST / PwD aur CIL Employees exempted hain."},{heading:"Reference Marker",items:["CIL MT 2026 ke expected examination schedule, portal walkthrough aur exam pattern ke liye CIL Management Trainee 2026 Exam Overview Video dekh sakte hain."]}]},{title:"SBI SCO Trade Finance Officer Examination 2026",lastDateLabel:"Online Apply Last Date",lastDate:"02 June 2026",feeHeading:"Fee Details",feeItems:["For General / OBC / EWS: Rs 750/-","For SC / ST / PwBD: Rs 00/-"],sections:[{heading:"Personal & Identity Card",items:["Brief Resume / Bio-data: Updated professional CV PDF format me.","Identity Proof: Aadhaar Card, PAN Card, Voter ID, ya Passport PDF format me.","Age Proof: 10th Class Certificate ya Marksheet.","Passport Photo & Signature: Recent color photograph aur scanned JPG signature."]},{heading:"Educational & Mandatory Professional Certification Card",items:["Graduation Degree: Kisi bhi stream ki graduation degree certificate ya final marksheet.","Forex Certification (Mandatory): IIBF se Certification in Forex Operations compulsory hai.","Note: Yeh certificate 30 April 2026 ya usse pehle issue hua hona chahiye.","Preferred Certifications: CDCS, Certificate in Trade Finance, ya Certificate in International Banking."]},{heading:"Work Experience & Job Profile Card",items:["Experience Certificates (Mandatory): Minimum 2 years ka scheduled commercial bank experience in Trade Finance Processing.","Specific Experience Proof: Joining letter, promotion orders, ya relieving letters ko PDF me combine kar lein.","No Objection Certificate (NOC): Government Organization, PSU, ya Public Sector Bank me currently working candidates ke liye mandatory."]},{heading:"Reservation & Category Card",items:["Caste Certificate: SC / ST / OBC (Non-Creamy Layer) candidates ke liye.","EWS / PwBD Certificate: Valid certificate benefit claim karne ke liye."]}]}]},"Home Guard Form":{overview:"Home Guard-specific recruitment requirements are listed separately here, including service record checks and Bihar reservation documents.",openings:[{title:"BPSSC Bihar Police Havildar Instructor Home Guard Examination 2026",lastDateLabel:"Online Apply Last Date",lastDate:"09 June 2026",feeHeading:"Fee Details",feeItems:["For All Category Candidates: Rs 100/-"],sections:[{heading:"Personal & Identity Card",items:["Identity Proof: Aadhaar Card, PAN Card, Voter ID, ya Driving License.","Passport Size Photo: Fresh color photograph (JPEG format, clear background).","Signature: Do alag files, ek Hindi me aur ek English me scanned signature.","Contact Info: Active Mobile Number aur Email ID."]},{heading:"Academic & Service Experience Card",items:["10th Class (Matriculation): Marksheet aur Passing Certificate, name aur DoB proof ke liye mandatory.","12th Class (Intermediate) / Graduation: Marksheet aur Certificate, post requirement ke anusar.","Home Guard Service Certificate (Compulsory): Bihar Home Guard me active service period ka certificate / service book aur enrollment number."]},{heading:"Bihar Reservation & Category Card",items:["Domicile (Mool Niwasi) Certificate: Bihar permanent resident proof.","Caste Certificate: SC / ST candidates ke liye.","Non-Creamy Layer (NCL) Certificate: BC aur EBC candidates ke liye updated praman patra.","EWS Certificate: General category ke Economically Weaker Section candidates ke liye."],note:"Crucial Form-Fill Tip: Service Book aur 10th marksheet me naam ki spelling exact match honi chahiye."}]}]},"Air Force Form":{overview:"Air Force-related application details are listed here with offline and online submission markers kept in the correct section.",openings:[{title:"Indian Air Force Group C Civilian Examination 2026",lastDateLabel:"Online Apply Last Date",lastDate:"01 June 2026",feeHeading:"Fee Details",feeItems:["For All Category Candidates: Rs 00/-"],sections:[{heading:"Personal & Identity Card",items:["Identity Proof: Aadhaar Card, PAN Card, Voter ID, ya Passport.","Passport Size Photos: Do se teen fresh color photographs. Offline form ke liye paste aur self-attest karna hota hai.","Signature: Scanned signature (online) ya offline form ke prescribed box me signature.","Contact Info: Active Mobile Number aur Email ID."]},{heading:"Academic & Skill Qualification Card",items:["10th Class (Matriculation): Marksheet aur Passing Certificate, exact name aur DoB proof ke liye mandatory.","12th Class (Intermediate): Marksheet aur Certificate, LDC aur Typist posts ke liye zaroori.","Experience Certificate: Cook, Fireman, Carpenter jaise trades ke liye agar required ho.","Skill Test Proof / Typing Certificate: LDC aur Typist posts ke liye typing speed ya skill proficiency proof."]},{heading:"Reservation & Self-Address Card",items:["Domicile (Niwasi) Certificate: State / region residential proof.","Caste Certificate: SC / ST / OBC (Non-Creamy Layer) candidates ke liye Central Government format me.","EWS / PwD Certificate: Valid certificate benefit ke liye.","Self-Addressed Envelope: Offline application ke sath required postage stamp laga hua envelope bhejna hota hai."],note:"Crucial Check: Offline form bhejte waqt envelope par APPLICATION FOR THE POST OF _______ AND CATEGORY _______ likhna na bhoolein."}]}]}};export{e as s};
